local function makeRightBtn(txt, yOff, bgColor, strokeColor)
    local b = Instance.new("TextButton", RightPanel)
    b.Size = UDim2.new(1, -8, 0, 34)
    b.Position = UDim2.new(0, 4, 0, yOff)
    b.BackgroundColor3 = bgColor
    b.BorderSizePixel = 0
    b.Text = txt
    b.Font = Enum.Font.GothamBold
    b.TextSize = 9
    b.TextColor3 = Color3.fromRGB(210, 210, 235)
    b.ZIndex = 3
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)

    -- inner border stroke
    local s = Instance.new("UIStroke", b)
    s.Thickness = 1
    s.Color = strokeColor
    s.Transparency = 0.25
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    b.MouseEnter:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.12), {
            BackgroundColor3 = Color3.new(
                math.min(bgColor.R + 0.06, 1),
                math.min(bgColor.G + 0.06, 1),
                math.min(bgColor.B + 0.06, 1)
            )
        }):Play()
    end)
    b.MouseLeave:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.12), {BackgroundColor3 = bgColor}):Play()
    end)

    return b, s
end

