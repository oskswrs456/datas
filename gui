-- LIST BUILDER
-- =====================================================
local selected = nil
local buttons = {}

local function clearList()
    for _, o in ipairs(buttons) do o:Destroy() end
    buttons = {}
    selected = nil
end

function buildList(list)
    clearList()
    if #list == 0 then
        setStatus("None found", Color3.fromRGB(255, 180, 80))
        local e = Instance.new("TextLabel", Scroll)
        e.Size = UDim2.new(1, 0, 0, 36)
        e.BackgroundTransparency = 1
        e.Text = "No brainrots\non your base"
        e.Font = Enum.Font.Gotham
        e.TextSize = 9
        e.TextWrapped = true
        e.TextColor3 = Color3.fromRGB(100, 100, 130)
        e.ZIndex = 4
        table.insert(buttons, e)
        return
    end

    setStatus(#list .. " found", Color3.fromRGB(80, 200, 120))

    for _, br in ipairs(list) do
        local item = Instance.new("TextButton", Scroll)
        item.Size = UDim2.new(1, 0, 0, 48)
        item.BackgroundColor3 = Color3.fromRGB(25, 25, 34)
        item.BorderSizePixel = 0
        item.Text = ""
        item.ZIndex = 4
        Instance.new("UICorner", item).CornerRadius = UDim.new(0, 8)

        -- INNER BORDER STROKE
        local iStroke = Instance.new("UIStroke", item)
        iStroke.Thickness = 1
        iStroke.Color = Color3.fromRGB(55, 50, 80)
        iStroke.Transparency = 0.3
        iStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

        local nLbl = Instance.new("TextLabel", item)
        nLbl.Size = UDim2.new(1, -8, 0, 24)
        nLbl.Position = UDim2.new(0, 6, 0, 4)
        nLbl.BackgroundTransparency = 1
        nLbl.Text = br.name
        nLbl.Font = Enum.Font.GothamBold
        nLbl.TextSize = 10
        nLbl.TextColor3 = Color3.fromRGB(220, 220, 245)
        nLbl.TextXAlignment = Enum.TextXAlignment.Left
        nLbl.TextWrapped = true
        nLbl.ZIndex = 5

        local gLbl = Instance.new("TextLabel", item)
        gLbl.Size = UDim2.new(1, -8, 0, 14)
        gLbl.Position = UDim2.new(0, 6, 0, 30)
        gLbl.BackgroundTransparency = 1
        gLbl.Text = br.genText
        gLbl.Font = Enum.Font.Gotham
        gLbl.TextSize = 9
        gLbl.TextColor3 = Color3.fromRGB(80, 200, 120)
        gLbl.TextXAlignment = Enum.TextXAlignment.Left
        gLbl.ZIndex = 5

        local function onSelect()
            selected = br
            for _, b in ipairs(buttons) do
                if b:IsA("TextButton") then
                    TweenService:Create(b, TweenInfo.new(0.12), {
                        BackgroundColor3 = Color3.fromRGB(25, 25, 34)
                    }):Play()
                    local st = b:FindFirstChildWhichIsA("UIStroke")
                    if st then
                        st.Color = Color3.fromRGB(55, 50, 80)
                        st.Transparency = 0.3
                    end
                end
            end
            TweenService:Create(item, TweenInfo.new(0.12), {
                BackgroundColor3 = Color3.fromRGB(32, 24, 50)
            }):Play()
            iStroke.Color = Color3.fromRGB(130, 80, 220)
            iStroke.Transparency = 0
            setStatus("Selected:\n" .. br.name, Color3.fromRGB(140, 100, 255))
        end

        item.MouseButton1Click:Connect(onSelect)
        item.TouchTap:Connect(onSelect)
        table.insert(buttons, item)
    end
end

